    "import automol\n",
    "from pathlib import Path\n",
    "\n",
    "geo_file = Path(\"opt.xyz\")\n",
    "geo = automol.geom.from_xyz_string(geo_file.read_text())\n",
    "\n",
    "automol.geom.display(geo, label=True)"
